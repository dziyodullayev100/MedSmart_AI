# ==========================================
# MedSmart Environment Variables Reference
# ==========================================

# Node.js Environment (development | production)
NODE_ENV=production

# Server deployment port
PORT=5000

# JSON Web Token Secret (Required for production authentication)
# Generate a secure 64-character random string for this value
JWT_SECRET=your_super_secret_jwt_key_here

# Python AI Service Internal Endpoint URL
# Should point to docker internal name or external render.com domain
AI_SERVICE_URL=http://ai_service:8000

# PostgreSQL DB Connection URL (leave blank to default to SQLite)
# Example: postgres://user:pass@host:5432/medsmart_db
DATABASE_URL=

# Enable Demo Seed Generation & Tours (true | false)
DEMO_MODE=true

# Enable SQLite auto-backup scheduling (true | false)
BACKUP_ENABLED=true
